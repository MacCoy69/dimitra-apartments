---
pagination:
  data: site.languages
  size: 1
  alias: lang
permalink: "/{{ lang }}/index.html"
layout: base.njk
pageKey: home
slug: ""
theme: over
---
{%- set L = i18n[lang] -%}
{%- set H = L.home -%}

<!-- Hero -->
<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__media">
    <video autoplay muted loop playsinline poster="/img/penthouse-ausblick-01.webp" aria-hidden="true">
      <source src="/video/hero.mp4" type="video/mp4">
    </video>
  </div>
  <div class="container">
    <div class="hero__inner">
      <p class="eyebrow reveal">{{ H.heroEyebrow }}</p>
      <h1 id="hero-heading" class="reveal d1">Dimitra Beach<span class="script">Apartments</span></h1>
      <p class="hero__sub reveal d2">{{ H.heroSub }}</p>
      <div class="hero__cta reveal d3">
        <a href="#auswahl" class="btn btn--primary">{{ H.heroCta1 }}</a>
        <a href="#kontakt" class="btn btn--light">{{ H.heroCta2 }}</a>
      </div>
    </div>
  </div>
  <div class="scroll-cue" aria-hidden="true"><span class="line"></span>{{ H.scroll }}</div>
</section>

<!-- Auswahl -->
<section id="auswahl" class="section" aria-labelledby="auswahl-heading">
  <svg class="deco deco--tr deco--float" aria-hidden="true"><use href="#d-sun"/></svg>
  <svg class="deco deco--bl deco--float alt" aria-hidden="true"><use href="#d-fish"/></svg>
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">{{ H.auswahlEyebrow }}</span>
      <h2 id="auswahl-heading" class="section-title">{{ H.auswahlTitle }}</h2>
      <svg class="doodle-rule" width="90" height="12" aria-hidden="true"><use href="#d-squiggle"/></svg>
      <p class="lead">{{ H.auswahlLead }}</p>
    </div>
    <div class="choice-circles">
      <article class="choice-circle reveal">
        <a href="/{{ lang }}/thassos/" class="round-media" aria-label="{{ H.thassosCard.cta }}"><img src="/img/penthouse-terrasse-01.webp" alt="{{ H.thassosCard.alt }}" loading="lazy"></a>
        <span class="choice-circle__tag"><svg width="15" height="15"><use href="#i-pin"/></svg> {{ H.thassosCard.tag }}</span>
        <h3>Thassos</h3>
        <span class="script">{{ H.thassosCard.script }}</span>
        <p>{{ H.thassosCard.text }}</p>
        <a href="/{{ lang }}/thassos/" class="btn btn--primary">{{ H.thassosCard.cta }}</a>
      </article>
      <article class="choice-circle reveal d1">
        <a href="/{{ lang }}/festland/" class="round-media" aria-label="{{ H.festlandCard.cta }}"><img src="/img/apartment-terrasse-04.webp" alt="{{ H.festlandCard.alt }}" loading="lazy"></a>
        <span class="choice-circle__tag"><svg width="15" height="15"><use href="#i-pin"/></svg> {{ H.festlandCard.tag }}</span>
        <h3>{{ L.nav.festland }}</h3>
        <span class="script">{{ H.festlandCard.script }}</span>
        <p>{{ H.festlandCard.text }}</p>
        <a href="/{{ lang }}/festland/" class="btn btn--primary">{{ H.festlandCard.cta }}</a>
      </article>
    </div>
  </div>
</section>

<!-- Welcome -->
<section class="section section--alt" aria-labelledby="welcome-heading">
  <svg class="deco deco--tr deco--float" aria-hidden="true" style="width:clamp(40px,5vw,64px)"><use href="#d-olive"/></svg>
  <div class="container">
    <div class="editorial">
      <div class="editorial__media collage reveal">
        <img src="/img/apartment-wohnzimmer-01.webp" alt="{{ H.welcome.alt1 }}" loading="lazy" width="600" height="750">
        <span class="editorial__inset"><img src="/img/apartment-terrasse-01.webp" alt="{{ H.welcome.alt2 }}" loading="lazy"></span>
        <span class="stamp">{{ H.welcome.stamp }}</span>
      </div>
      <div class="editorial__body reveal d1">
        <span class="eyebrow">{{ H.welcome.eyebrow }}</span>
        <h2 id="welcome-heading">{{ H.welcome.title }}</h2>
        <svg class="doodle-rule" width="90" height="12" aria-hidden="true" style="margin-top:.4rem;color:var(--color-secondary)"><use href="#d-squiggle"/></svg>
        <p style="margin-top:1.2rem;">{{ H.welcome.p1 }}</p>
        <p>{{ H.welcome.p2 }}</p>
        <p class="signature">{{ H.welcome.signature }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Momente -->
<section class="section" aria-labelledby="momente-heading">
  <svg class="deco deco--bl deco--float" aria-hidden="true" style="width:clamp(46px,6vw,78px)"><use href="#d-wave"/></svg>
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">{{ H.momente.eyebrow }}</span>
      <h2 id="momente-heading" class="section-title">{{ H.momente.title }}</h2>
      <svg class="doodle-rule" width="90" height="12" aria-hidden="true"><use href="#d-squiggle"/></svg>
    </div>
    {%- set momImgs = ['apartment-terrasse-04','penthouse-terrasse-03','penthouse-ausblick-01'] -%}
    <div class="moments-grid">
      {%- for m in H.momente.items %}
      <article class="moment reveal {{ 'd' + loop.index0 if loop.index0 }}">
        <div class="round-media"><img src="/img/{{ momImgs[loop.index0] }}.webp" alt="{{ m.title }}" loading="lazy"></div>
        <span class="script">{{ m.script }}</span>
        <h3>{{ m.title }}</h3>
        <p>{{ m.text }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Ausstattung -->
<section id="ausstattung" class="section section--alt" aria-labelledby="ausstattung-heading">
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">{{ H.ausstattung.eyebrow }}</span>
      <h2 id="ausstattung-heading" class="section-title">{{ H.ausstattung.title }}</h2>
      <svg class="doodle-rule" width="90" height="12" aria-hidden="true"><use href="#d-squiggle"/></svg>
      <p class="lead">{{ H.ausstattung.lead }}</p>
    </div>
    {%- set amenIcons = ['i-wifi','i-parking','i-grill','i-kitchen','i-sea','i-beach'] -%}
    <div class="amen-grid">
      {%- for a in H.ausstattung.items %}
      <div class="amenity reveal {{ 'd' + (loop.index0 % 3) if (loop.index0 % 3) }}"><div class="amenity__icon"><svg><use href="#{{ amenIcons[loop.index0] }}"/></svg></div><h3>{{ a.title }}</h3><p>{{ a.text }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Galerie -->
<section class="section" aria-labelledby="galerie-heading">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{{ H.galerie.eyebrow }}</span>
      <h2 id="galerie-heading" class="section-title">{{ H.galerie.title }}</h2>
    </div>
    <div class="gallery reveal" data-lightbox>
      <figure class="wide"><img src="/img/penthouse-terrasse-03.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure class="tall"><img src="/img/apartment-schlafzimmer-01.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure><img src="/img/apartment-kueche-01.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure><img src="/img/penthouse-wohnzimmer-03.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure><img src="/img/apartment-bad-01.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure><img src="/img/apartment-terrasse-01.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure class="wide"><img src="/img/penthouse-terrasse-05.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
      <figure><img src="/img/apartment-wohnzimmer-04.webp" alt="{{ H.galerie.title }}" loading="lazy"></figure>
    </div>
  </div>
</section>

<!-- Lage -->
<section id="lage" class="section section--alt" aria-labelledby="lage-heading">
  <div class="container">
    <div class="loc-grid">
      <div class="reveal">
        <span class="eyebrow">{{ H.lage.eyebrow }}</span>
        <h2 id="lage-heading" class="section-title" style="margin:1rem 0 .6rem;">{{ H.lage.title }}</h2>
        <p class="lead">{{ H.lage.lead }}</p>
        <ul class="dist-list">
          <li><span class="place"><svg><use href="#i-beach"/></svg> {{ H.lage.d1 }}</span><span class="km">700 m</span></li>
          <li><span class="place"><svg><use href="#i-pin"/></svg> {{ H.lage.d2 }}</span><span class="km">2,8 km</span></li>
          <li><span class="place"><svg><use href="#i-ferry"/></svg> {{ H.lage.d3 }}</span><span class="km">13 km</span></li>
          <li><span class="place"><svg><use href="#i-plane"/></svg> {{ H.lage.d4 }}</span><span class="km">34 km</span></li>
        </ul>
      </div>
      <div class="map-card reveal d1">
        <iframe title="{{ H.lage.mapTitle }}" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://www.openstreetmap.org/export/embed.html?bbox=24.70%2C40.62%2C24.80%2C40.69&amp;layer=mapnik&amp;marker=40.655%2C24.745"></iframe>
      </div>
    </div>
  </div>
</section>

<!-- Kontakt -->
<section id="kontakt" class="section section--deep" aria-labelledby="kontakt-heading">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-aside reveal">
        <span class="eyebrow" style="color:var(--color-primary-light)">{{ H.kontakt.eyebrow }}</span>
        <h2 id="kontakt-heading" style="margin-top:1rem;">{{ H.kontakt.title }}</h2>
        <p>{{ H.kontakt.text }}</p>
        <a href="#" class="btn btn--primary" style="margin:.6rem 0 1.8rem;">{{ H.kontakt.bookBtn }} <svg width="15" height="15"><use href="#i-arrow"/></svg></a>
        <div class="contact-channels">
          <a href="https://wa.me/300000000000" target="_blank" rel="noopener"><span class="ic"><svg><use href="#i-whatsapp"/></svg></span><span>WhatsApp<small>{{ H.kontakt.waNote }}</small></span></a>
          <a href="mailto:info@dimitra-apartments.gr"><span class="ic"><svg><use href="#i-mail"/></svg></span><span>info@dimitra-apartments.gr<small>E-Mail</small></span></a>
          <a href="tel:+300000000000"><span class="ic"><svg><use href="#i-phone"/></svg></span><span>+30 000 000 0000<small>{{ H.kontakt.phoneNote }}</small></span></a>
        </div>
      </div>
      <form id="anfrage-form" class="form-card reveal d1" novalidate>
        <div class="form-success" role="status" aria-live="polite">{{ H.kontakt.form.success }}</div>
        <h3 style="font-family:var(--font-display);font-weight:500;font-size:1.5rem;margin-bottom:1.1rem;">{{ H.kontakt.form.heading }}</h3>
        <div class="form-row">
          <div class="field"><label for="name">{{ H.kontakt.form.name }}</label><input type="text" id="name" name="name" autocomplete="name" required></div>
          <div class="field"><label for="email">{{ H.kontakt.form.email }}</label><input type="email" id="email" name="email" autocomplete="email" required></div>
        </div>
        <div class="form-row">
          <div class="field"><label for="ziel">{{ H.kontakt.form.ziel }}</label>
            <select id="ziel" name="ziel">
              <option value="" selected>{{ H.kontakt.form.zielPlaceholder }}</option>
              <option>Thassos – Skala Potamias</option>
              <option>{{ L.nav.festland }} – Nea Karvali</option>
              <option>{{ H.kontakt.form.zielUndecided }}</option>
            </select>
          </div>
          <div class="field"><label for="tel">{{ H.kontakt.form.phone }}</label><input type="tel" id="tel" name="tel" autocomplete="tel"></div>
        </div>
        <div class="field"><label for="nachricht">{{ H.kontakt.form.message }}</label><textarea id="nachricht" name="nachricht" placeholder="{{ H.kontakt.form.messagePlaceholder }}"></textarea></div>
        <label class="consent"><input type="checkbox" required> {{ H.kontakt.form.consentPre }} <a href="/{{ lang }}/datenschutz/">{{ L.legal.datenschutz }}</a> {{ H.kontakt.form.consentPost }}</label>
        <button type="submit" class="btn btn--primary btn--block">{{ H.kontakt.form.submit }}</button>
      </form>
    </div>
  </div>
</section>
